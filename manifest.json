{
  "manifest_version": 3,
  "name": "system-ui for 𝕏",
  "version": "1.0",
  "description": "𝕏（旧Twitter）のフォントをsystem-uiに変更するChrome拡張機能です。",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["https://x.com/*", "https://twitter.com/*"],
      "css": ["style.css"],
      "run_at": "document_start"
    }
  ]
}
